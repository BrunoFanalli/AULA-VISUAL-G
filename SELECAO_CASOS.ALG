algoritmo "selecao_casos"

var
   opcao: inteiro

inicio

   escreva("1 - Opçăo 1")
   escreva("2 - Opçăo 2")
   escreva("3 - Opçăo 3")
   escreva("Escolha uma opçăo: ")
   leia(opcao)

   escolha opcao

      caso 1
         escreval("Vocę escolheu a opçăo 1")

      caso 2
         escreval("Vocę escolheu a opçăo 2")

      caso 3
         escreval("Vocę escolheu a opçăo 3")

      outrocaso
         escreval("Opçăo inválida")

   fimescolha

fimalgoritmo