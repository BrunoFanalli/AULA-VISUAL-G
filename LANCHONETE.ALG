algoritmo "lanchonete"

var
   pedido: inteiro

inicio

   escreval("1 - Hambúrguer")
   escreval("2 - Pizza")
   escreval("3 - Cachorro-quente")

   leia(pedido)

   escolha pedido

      caso 1
         escreval("Vocę escolheu Hambúrguer")

      caso 2
         escreval("Vocę escolheu Pizza")

      caso 3
         escreval("Vocę escolheu Cachorro-quente")

      outrocaso
         escreval("Pedido inválido")

   fimescolha

fimalgoritmo